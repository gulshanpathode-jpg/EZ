{
  "manifest_version": 3,
  "name": "Smart Fill - EZ inspections",
  "version": "0.2.0",
  "description": "Scrapes inspection Q&A + labeled photos, verifies answers with AI, and highlights matches/mismatches.",
  "permissions": ["sidePanel", "activeTab", "scripting", "storage", "unlimitedStorage", "tabs"],
  "host_permissions": [
    "https://www.ezinspections.com/*",
    "https://ezinspections.com/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Smart Fill - EZ inspections"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ezinspections.com/inspManager/*",
        "https://ezinspections.com/inspManager/*"
      ],
      "js": ["imageModal.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
